model Phone {
    id        Int      @id @default(autoincrement())
    phone     String   @db.VarChar(15)
    userId    Int      @unique
    user      User     @relation(fields: [userId], references: [id])
    createdAt DateTime @default(now()) @db.Timestamp()
    updatedAt DateTime @default(now()) @updatedAt @db.Timestamp()

    @@map("phones")
}
